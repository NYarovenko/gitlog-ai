# ║  Скопіюй цей файл і збережи як: .env.local              ║
# ╚══════════════════════════════════════════════════════════╝

# ── 1. ANTHROPIC API (для AI-генерації) ─────────────────────
# → https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-ВСТАВТЕ_СВІЙ_КЛЮЧ_ТУТ

# ── 2. GUMROAD (для оплати, Україна + PayPal ✅) ─────────────
# → https://gumroad.com → реєстрація безкоштовна

# Посилання на продукти (після створення на Gumroad)
# Виглядають як: https://YOUR_NAME.gumroad.com/l/PRODUCT_ID
NEXT_PUBLIC_GUMROAD_STARTER_URL=https://ТВІЙ_НІКНЕЙМ.gumroad.com/l/STARTER_ID
NEXT_PUBLIC_GUMROAD_PRO_URL=https://ТВІЙ_НІКНЕЙМ.gumroad.com/l/PRO_ID

# ── 3. URL САЙТУ ─────────────────────────────────────────────
# Після деплою на Vercel — вставте реальний домен
NEXT_PUBLIC_APP_URL=https://ВАШ_ДОМЕН.vercel.app
